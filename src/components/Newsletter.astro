---

<div class="mt-10 rounded-xl border border-gray-200 bg-gray-50 p-6 text-center dark:border-gray-700 dark:bg-gray-800/50">
	<h3 class="text-lg font-semibold text-brand dark:text-white">Stay in the loop</h3>
	<p class="mt-1 text-sm text-muted dark:text-gray-400">
		Get new posts and updates delivered to your inbox. No spam, unsubscribe anytime.
	</p>
	<form id="newsletter-form" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center">
		<input
			type="email"
			name="email"
			placeholder="you@example.com"
			required
			class="w-full rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm text-brand outline-none transition focus:border-brand-light dark:border-gray-600 dark:bg-surface-dark dark:text-white sm:max-w-xs"
		/>
		<button
			type="submit"
			class="rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-light dark:bg-white dark:text-brand dark:hover:bg-gray-200"
		>
			Subscribe
		</button>
	</form>
	<p id="newsletter-success" class="mt-3 hidden text-sm text-green-600 dark:text-green-400">
		Thanks for subscribing!
	</p>
	<p id="newsletter-error" class="mt-3 hidden text-sm text-red-600 dark:text-red-400">
		Something went wrong. Please try again.
	</p>
</div>

<script>
	const form = document.getElementById('newsletter-form') as HTMLFormElement;
	const success = document.getElementById('newsletter-success')!;
	const error = document.getElementById('newsletter-error')!;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const email = new FormData(form).get('email') as string;

		// TODO: Replace with actual API endpoint (e.g., Amazon SES, Mailchimp, ConvertKit)
		// For now, simulate success
		try {
			// await fetch('/api/newsletter', { method: 'POST', body: JSON.stringify({ email }) });
			form.classList.add('hidden');
			success.classList.remove('hidden');
			error.classList.add('hidden');
		} catch {
			error.classList.remove('hidden');
		}
	});
</script>

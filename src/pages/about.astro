---
import { Image } from 'astro:assets';
import authorImage from '../assets/about/author.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
	<head>
		<BaseHead title="About" description="About John Buzzanca — author of The Smuggler's Daughter" />
	</head>

	<body>
		<Header />
		<main class="mx-auto max-w-4xl px-6 py-16">
			<section class="flex flex-col items-center gap-10 md:flex-row md:items-start">
				<div class="shrink-0">
					<Image
						src={authorImage}
						alt="John Buzzanca"
						width={280}
						height={280}
						class="rounded-2xl object-cover shadow-lg"
					/>
				</div>
				<div>
					<h1 class="mb-4 text-3xl font-bold tracking-tight text-brand dark:text-white">About the Author</h1>
					<p class="mb-4 leading-relaxed text-muted dark:text-gray-300">
						<strong class="text-brand dark:text-white">John Buzzanca</strong> is a writer and legal professional based in Southern Orange County, California. After leaving behind a life of smuggling along the California coast, he started a new career in the legal field in late 1993 — with no prior experience.
					</p>
					<p class="mb-4 leading-relaxed text-muted dark:text-gray-300">
						Determined to rebuild, he earned his A.A. from Saddleback College in 1999 and a bachelor's degree from Chapman University in 2005, all while working full-time and navigating wage garnishment from a landmark surrogacy custody case that made national headlines.
					</p>
					<p class="mb-4 leading-relaxed text-muted dark:text-gray-300">
						His unique perspective on the law is shaped by resilience, firsthand experience with criminal consequences, and the reality of 1990s surrogacy regulations. Through <em>The Smuggler's Daughter</em>, John shares his story as a cautionary tale — hoping to inspire, inform, and offer hard-won lessons from both sides of the law.
					</p>
					<a
						href="/timeline"
						class="mt-2 inline-block rounded-md border border-brand px-4 py-2 text-sm font-semibold text-brand no-underline transition-all hover:-translate-y-0.5 hover:bg-brand hover:text-white dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-brand"
					>
						View the Full Timeline →
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

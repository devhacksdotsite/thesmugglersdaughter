---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// Get all blog posts and sort by date (newest first)
const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

// Get the latest 3 posts
const latestPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--font-display: var(--font-manrope), sans-serif;
				--font-body: var(--font-manrope), sans-serif;
			}

			body {
				font-family: var(--font-body) !important;
				background: linear-gradient(135deg, #f5f5f7 0%, #ffffff 50%, #f0f0f5 100%);
				min-height: 100vh;
			}

			main {
				width: min(100%, 1320px);
				max-width: calc(100% - 2.5rem);
				margin: 0 auto;
				padding: 2rem 0 3rem;
			}

			@keyframes fadeIn {
				from { opacity: 0; transform: translateY(10px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}
			.hero {
				animation: fadeIn 0.8s ease-out both;
			}
			.posts-section {
				animation: fadeInUp 0.8s ease-out 0.2s both;
			}
			.stories-container {
				animation: fadeInUp 0.8s ease-out 0.4s both;
			}
			.archive-link {
				animation: fadeInUp 0.8s ease-out 0.6s both;
			}

			.hero {
				background: linear-gradient(135deg, #1e293b 0%, #334155 50%, #3b3466 100%);
				padding: 5rem 2rem 4rem 2rem;
				margin: 0 0 4rem;
				text-align: center;
				border-radius: 32px;
				border-bottom: 1px solid rgba(35, 55, 255, 0.3);
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: -50%;
				right: -10%;
				width: 500px;
				height: 500px;
				background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
				border-radius: 50%;
				z-index: 0;
			}

			.hero::after {
				content: '';
				position: absolute;
				bottom: -30%;
				left: -10%;
				width: 400px;
				height: 400px;
				background: radial-gradient(circle, rgba(93, 39, 209, 0.08) 0%, transparent 70%);
				border-radius: 50%;
				z-index: 0;
			}

			.hero > * {
				position: relative;
				z-index: 1;
			}

			.hero h1 {
				font-family: var(--font-display);
				font-size: 3.5rem;
				color: #ffffff;
				margin-bottom: 0.75rem;
				font-weight: 800;
				letter-spacing: -2px;
				line-height: 1.1;
			}

			.hero p {
				font-size: 1.15rem;
				color: rgba(255, 255, 255, 0.85);
				max-width: 680px;
				margin: 1.5rem auto 0;
				line-height: 1.8;
				font-weight: 400;
				letter-spacing: 0.3px;
			}

			@keyframes heroFadeUp {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}

			.hero-line {
				opacity: 0;
				animation: heroFadeUp 0.8s ease-out forwards;
			}

			.hero-line-1 {
				animation-delay: 0.2s;
				font-size: 1rem;
				text-transform: lowercase;
				letter-spacing: 2px;
				color: rgba(255, 255, 255, 0.7);
				margin-bottom: 0.5rem;
			}

			.hero-line-2 {
				animation-delay: 0.6s;
			}

			.hero-line-3 {
				animation-delay: 1s;
				font-size: 1.25rem;
				color: rgba(255, 255, 255, 0.9);
				margin-top: 1rem;
			}

			.posts-section {
				margin: 0 0 4rem;
				position: relative;
				overflow: hidden;
				border-radius: 28px;
				padding: 3rem 1.5rem 2rem;
				background: rgba(15, 18, 25, 0.04);
			}

			.posts-section video {
				position: absolute;
				inset: -8% 0;
				width: 100%;
				height: 116%;
				object-fit: cover;
				object-position: center;
				z-index: 0;
				display: block;
				opacity: 0.24;
				transform: scale(1.05);
				filter: saturate(1.05) contrast(1.05);
			}

			.posts-section > * {
				position: relative;
				z-index: 1;
			}

			.posts-section h2 {
				font-family: var(--font-display);
				font-size: 2.8rem;
				color: #0f1219;
				margin-bottom: 0.5rem;
				text-align: center;
				font-weight: 800;
				letter-spacing: -1px;
			}

			.posts-section > p {
				text-align: center;
				color: rgba(15, 18, 25, 0.6);
				font-size: 1rem;
				margin-bottom: 3rem;
				letter-spacing: 0.5px;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2.5rem;
				margin-bottom: 4rem;
			}

			.post-card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 10px 30px rgba(15, 18, 25, 0.08), 0 1px 3px rgba(15, 18, 25, 0.12);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				display: flex;
				flex-direction: column;
				border: 1px solid rgba(35, 55, 255, 0.05);
			}

			.post-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 25px 50px rgba(15, 18, 25, 0.15), 0 2px 8px rgba(35, 55, 255, 0.2);
				border-color: rgba(35, 55, 255, 0.15);
			}

			.post-image {
				width: 100%;
				height: 240px;
				object-fit: cover;
				background: linear-gradient(135deg, #f0f4ff 0%, #f5f0ff 100%);
				transition: transform 0.4s ease;
			}

			.post-card:hover .post-image {
				transform: scale(1.05);
			}

			.post-content {
				padding: 2rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.post-date {
				font-size: 0.8rem;
				color: rgba(15, 18, 25, 0.5);
				margin-bottom: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1.2px;
				font-weight: 600;
			}

			.post-card h3 {
				font-family: var(--font-display);
				font-size: 1.75rem;
				margin: 0.5rem 0 1rem 0;
				color: #0f1219;
				line-height: 1.3;
				font-weight: 700;
				letter-spacing: -0.5px;
			}

			.post-description {
				color: rgba(15, 18, 25, 0.7);
				font-size: 0.95rem;
				line-height: 1.7;
				margin-bottom: 1.5rem;
				flex-grow: 1;
				letter-spacing: 0.3px;
			}

			.post-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: #2337ff;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95rem;
				transition: all 0.3s ease;
				width: fit-content;
				letter-spacing: 0.3px;
			}

			.post-link:hover {
				color: #000d8a;
				gap: 0.75rem;
			}

			.stories-container {
				display: flex;
				justify-content: center;
				gap: 1.25rem;
				flex-wrap: wrap;
				margin: 0 0 3rem;
				padding: 0;
			}

			.story-card {
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				padding: 2.75rem 3rem;
				border-radius: 0.9rem;
				text-decoration: none;
				border: 1px solid transparent;
				flex: 1 1 320px;
				max-width: 430px;
				min-height: 250px;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				position: relative;
				overflow: hidden;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.story-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: rgba(46, 68, 73, 0.6);
				z-index: 1;
				border-radius: 0.5rem;
				pointer-events: none;
			}

			.story-card h3,
			.story-card p {
				position: relative;
				z-index: 2;
				color: white;
			}

			.story-card h3 {
				margin: 0;
				font-family: var(--font-display);
				font-size: 1.7rem;
				letter-spacing: -0.5px;
				font-weight: 600;
			}

			.story-card p {
				margin: 0.75rem 0 0 0;
				opacity: 0.95;
				line-height: 1.6;
				font-size: 1.05rem;
			}

			.story-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 15px 40px rgba(46, 68, 73, 0.4);
			}

			.story-card:active {
				transform: translateY(-1px);
			}

			.dark .story-card h3,
			.dark .story-card p {
				color: white;
			}

			.dark .story-card:hover {
				box-shadow: 0 20px 50px rgba(46, 68, 73, 0.5);
			}

			.dark body {
				background: linear-gradient(135deg, #111827 0%, #0f172a 50%, #020617 100%);
			}

			.dark .posts-section h2 {
				color: #f9fafb;
			}

			.dark .posts-section > p {
				color: rgba(255, 255, 255, 0.72);
			}

			.dark .post-card {
				background: rgba(17, 24, 39, 0.95);
				border: 1px solid rgba(255, 255, 255, 0.08);
				box-shadow: 0 10px 30px rgba(2, 6, 23, 0.45), 0 1px 3px rgba(2, 6, 23, 0.35);
			}

			.dark .post-card:hover {
				box-shadow: 0 20px 45px rgba(2, 6, 23, 0.6), 0 2px 8px rgba(35, 55, 255, 0.2);
				border-color: rgba(35, 55, 255, 0.25);
			}

			.dark .post-image {
				background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
			}

			.dark .post-date {
				color: rgba(255, 255, 255, 0.6);
			}

			.dark .post-card h3 {
				color: #f9fafb;
			}

			.dark .post-description {
				color: rgba(255, 255, 255, 0.72);
			}

			.dark .post-link {
				color: #8bb4ff;
			}

			.dark .post-link:hover {
				color: #c7d9ff;
			}

			.dark .archive-link {
				border-top-color: rgba(255, 255, 255, 0.12);
			}

			.dark .archive-link a {
				box-shadow: 0 8px 20px rgba(35, 55, 255, 0.28);
			}

			.reviews-section {
				margin-top: 4rem;
				text-align: center;
			}

			.reviews-section h2 {
				font-family: var(--font-display);
				font-size: 2rem;
				color: #0f1219;
				margin-bottom: 2rem;
				font-weight: 700;
			}

			.reviews-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			.reviews-grid blockquote {
				background: white;
				border: 1px solid rgba(35, 55, 255, 0.08);
				border-radius: 12px;
				padding: 1.5rem;
				text-align: left;
				margin: 0;
				font-size: 1rem;
				border-left: none;
			}

			.reviews-grid blockquote p {
				color: rgba(15, 18, 25, 0.75);
				font-style: italic;
				line-height: 1.7;
				margin: 0;
			}

			.reviews-grid cite {
				display: block;
				margin-top: 0.75rem;
				font-size: 0.8rem;
				color: rgba(15, 18, 25, 0.5);
				font-style: normal;
			}

			.dark .reviews-section h2 {
				color: #f9fafb;
			}

			.dark .reviews-grid blockquote {
				background: rgba(17, 24, 39, 0.95);
				border-color: rgba(255, 255, 255, 0.08);
			}

			.dark .reviews-grid blockquote p {
				color: rgba(255, 255, 255, 0.75);
			}

			.dark .reviews-grid cite {
				color: rgba(255, 255, 255, 0.5);
			}

			.archive-link {
				text-align: center;
				margin-top: 3rem;
				padding-top: 3rem;
				border-top: 1px solid rgba(35, 55, 255, 0.1);
			}

			.archive-link .actions {
				display: flex;
				justify-content: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.archive-link a {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				background: #ffffff;
				color: #0f1219;
				padding: 0.9rem 1.5rem;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
				font-size: 0.95rem;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				letter-spacing: 0.02em;
				border: 1px solid #0f1219;
				box-shadow: 0 8px 20px rgba(15, 18, 25, 0.08);
			}

			.archive-link a:hover {
				transform: translateY(-2px);
				background: #0f1219;
				color: #ffffff;
				box-shadow: 0 12px 28px rgba(15, 18, 25, 0.16);
			}

			.archive-link a:active {
				transform: translateY(-1px);
			}

			@media (max-width: 640px) {
				.hero {
					padding: 3rem 1rem 2.5rem 1rem;
					margin: -3em -1em 2.5rem -1em;
				}

				.hero h1 {
					font-size: 2.25rem;
				}

				.hero p {
					font-size: 1rem;
				}

				.posts-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.posts-section h2 {
					font-size: 2rem;
				}

				.post-image {
					height: 200px;
				}

				.post-content {
					padding: 1.5rem;
				}

				.post-card h3 {
					font-size: 1.35rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<p class="hero-line hero-line-1">discover the untold story of...</p>
				<h1 class="hero-line hero-line-2">The Smuggler's Daughter</h1>
				<p class="hero-line hero-line-3">The <strong>INCREDIBLE</strong> journey of John Buzzanca</p>
			</div>

			<div class="posts-section">
				<video autoplay muted loop playsinline poster="/media/cover-1.webp">
					<source src="/media/trailer.mp4" type="video/mp4" />
				</video>
				<h2>Latest Stories</h2>
				<p>Explore our most recent narratives</p>
				<div class="posts-grid">
					{
						latestPosts.map((post) => (
							<article class="post-card">
								{post.data.heroImage && (
									<Image
										width={720}
										height={360}
										src={post.data.heroImage}
										alt={post.data.title}
										class="post-image"
									/>
								)}
								<div class="post-content">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<h3>{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
									<a href={`/blog/${post.id}`} class="post-link">
										Read More →
									</a>
								</div>
							</article>
						))
					}
				</div>
			</div>

			<div class="stories-container">
				<a href="/smuggler-story" class="story-card" style="background-image: url('https://images.leadconnectorhq.com/image/f_webp/q_80/r_900/u_https://assets.cdn.filesafe.space/ryFFM2PahlMxJvflm1nc/media/68bb418c1ff6ea7b62f4df41.png');">
					<h3>Smuggling Story</h3>
					<p>Risk, power, and betrayal</p>
				</a>
				<a href="/surrogate-story" class="story-card" style="background-image: url('https://images.leadconnectorhq.com/image/f_webp/q_80/r_900/u_https://assets.cdn.filesafe.space/ryFFM2PahlMxJvflm1nc/media/68bb4899460af21778791eec.png');">
					<h3>Surrogate Story</h3>
					<p>Love, law, and legacy</p>
				</a>
			</div>

			<!-- Timeline CTA -->
			<div style="text-align: center; margin: 3rem 0;">
				<a href="/timeline" style="display: inline-flex; align-items: center; gap: 0.5rem; color: inherit; text-decoration: none; font-weight: 600; font-size: 0.95rem; padding: 0.75rem 1.5rem; border: 1px solid rgba(31, 41, 55, 0.3); border-radius: 8px; transition: all 0.3s ease;">
					Explore the Full Timeline →
				</a>
			</div>

			<!-- Reviews -->
			<section class="reviews-section">
				<h2>What Readers Are Saying</h2>
				<div class="reviews-grid">
					<blockquote>
						<p>"A gripping true story that keeps you turning pages. Buzzanca's honesty is refreshing and the legal drama is fascinating."</p>
						<cite>— Amazon Reader</cite>
					</blockquote>
					<blockquote>
						<p>"Part crime thriller, part courtroom drama. The surrogacy case alone is worth the read — I had no idea this happened."</p>
						<cite>— Amazon Reader</cite>
					</blockquote>
				</div>
			</section>

			<div class="archive-link">
				<div class="actions">
					<a href="/blog">View All Stories</a>
					<a href="/trailer">Watch the Trailer</a>
				</div>
			</div>
		</main>
		<!-- Back to top button -->
		<button
			id="back-to-top"
			class="fixed bottom-6 right-6 z-50 hidden rounded-full bg-brand p-3 text-white shadow-lg transition-all hover:bg-brand-light dark:bg-white dark:text-brand dark:hover:bg-gray-200"
			aria-label="Back to top"
		>
			<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
		</button>

		<Footer />

		<script>
			const backToTop = document.getElementById('back-to-top')!;
			window.addEventListener('scroll', () => {
				backToTop.classList.toggle('hidden', window.scrollY < 300);
			}, { passive: true });
			backToTop.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		</script>
	</body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// Get all blog posts and sort by date (newest first)
const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

// Get the latest 3 posts
const latestPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--font-display: 'Playfair Display', serif;
				--font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
			}

			body {
				font-family: var(--font-body) !important;
				background: linear-gradient(135deg, #f5f5f7 0%, #ffffff 50%, #f0f0f5 100%);
				min-height: 100vh;
			}

			main {
				padding-top: 2rem !important;
			}

			.hero {
				background: linear-gradient(135deg, #0f1219 0%, #1a1f2e 50%, #2d1b4e 100%);
				padding: 5rem 2rem 4rem 2rem;
				margin: -3em -1em 4rem -1em;
				text-align: center;
				border-bottom: 1px solid rgba(35, 55, 255, 0.3);
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: -50%;
				right: -10%;
				width: 500px;
				height: 500px;
				background: radial-gradient(circle, rgba(35, 55, 255, 0.1) 0%, transparent 70%);
				border-radius: 50%;
				z-index: 0;
			}

			.hero::after {
				content: '';
				position: absolute;
				bottom: -30%;
				left: -10%;
				width: 400px;
				height: 400px;
				background: radial-gradient(circle, rgba(93, 39, 209, 0.08) 0%, transparent 70%);
				border-radius: 50%;
				z-index: 0;
			}

			.hero > * {
				position: relative;
				z-index: 1;
			}

			.hero h1 {
				font-family: var(--font-display);
				font-size: 3.5rem;
				color: #ffffff;
				margin-bottom: 0.75rem;
				font-weight: 800;
				letter-spacing: -2px;
				line-height: 1.1;
			}

			.hero p {
				font-size: 1.15rem;
				color: rgba(255, 255, 255, 0.85);
				max-width: 680px;
				margin: 1.5rem auto 0;
				line-height: 1.8;
				font-weight: 400;
				letter-spacing: 0.3px;
			}

			.posts-section {
				margin-top: 4rem;
				position: relative;
				overflow: hidden;
				border-radius: 28px;
				padding: 3rem 1.5rem 2rem;
				background: rgba(15, 18, 25, 0.04);
			}

			.posts-section video {
				position: absolute;
				inset: -8% 0;
				width: 100%;
				height: 116%;
				object-fit: cover;
				object-position: center;
				z-index: 0;
				display: block;
				opacity: 0.24;
				transform: scale(1.05);
				filter: saturate(1.05) contrast(1.05);
			}

			.posts-section > * {
				position: relative;
				z-index: 1;
			}

			.posts-section h2 {
				font-family: var(--font-display);
				font-size: 2.8rem;
				color: #0f1219;
				margin-bottom: 0.5rem;
				text-align: center;
				font-weight: 800;
				letter-spacing: -1px;
			}

			.posts-section > p {
				text-align: center;
				color: rgba(15, 18, 25, 0.6);
				font-size: 1rem;
				margin-bottom: 3rem;
				letter-spacing: 0.5px;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2.5rem;
				margin-bottom: 4rem;
			}

			.post-card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 10px 30px rgba(15, 18, 25, 0.08), 0 1px 3px rgba(15, 18, 25, 0.12);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				display: flex;
				flex-direction: column;
				border: 1px solid rgba(35, 55, 255, 0.05);
			}

			.post-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 25px 50px rgba(15, 18, 25, 0.15), 0 2px 8px rgba(35, 55, 255, 0.2);
				border-color: rgba(35, 55, 255, 0.15);
			}

			.post-image {
				width: 100%;
				height: 240px;
				object-fit: cover;
				background: linear-gradient(135deg, #f0f4ff 0%, #f5f0ff 100%);
				transition: transform 0.4s ease;
			}

			.post-card:hover .post-image {
				transform: scale(1.05);
			}

			.post-content {
				padding: 2rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.post-date {
				font-size: 0.8rem;
				color: rgba(15, 18, 25, 0.5);
				margin-bottom: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1.2px;
				font-weight: 600;
			}

			.post-card h3 {
				font-family: var(--font-display);
				font-size: 1.75rem;
				margin: 0.5rem 0 1rem 0;
				color: #0f1219;
				line-height: 1.3;
				font-weight: 700;
				letter-spacing: -0.5px;
			}

			.post-description {
				color: rgba(15, 18, 25, 0.7);
				font-size: 0.95rem;
				line-height: 1.7;
				margin-bottom: 1.5rem;
				flex-grow: 1;
				letter-spacing: 0.3px;
			}

			.post-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: #2337ff;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.95rem;
				transition: all 0.3s ease;
				width: fit-content;
				letter-spacing: 0.3px;
			}

			.post-link:hover {
				color: #000d8a;
				gap: 0.75rem;
			}

			.stories-container {
				display: flex;
				justify-content: center;
				gap: 1rem;
				flex-wrap: wrap;
				margin: 3rem 0;
				padding: 0;
			}

			.story-card {
				display: block;
				background: rgb(46, 68, 73);
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				color: white;
				padding: 2rem 2.5rem;
				border-radius: 12px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				letter-spacing: 0.5px;
				box-shadow: 0 8px 20px rgba(46, 68, 73, 0.3);
				border: 1px solid transparent;
				text-align: center;
				flex: 1;
				max-width: 350px;
				min-height: 200px;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				position: relative;
				overflow: hidden;
			}

			.story-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: rgba(46, 68, 73, 0.6);
				z-index: 1;
				border-radius: 12px;
				pointer-events: none;
			}

			.story-card h3,
			.story-card p {
				position: relative;
				z-index: 2;
			}

			.story-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 15px 40px rgba(46, 68, 73, 0.4);
				border-color: rgba(255, 255, 255, 0.2);
			}

			.story-card:active {
				transform: translateY(-1px);
			}

			.story-card h3 {
				margin: 0;
				font-family: var(--font-display);
				font-size: 1.5rem;
				letter-spacing: -0.5px;
			}

			.story-card p {
				margin: 0.75rem 0 0 0;
				font-size: 0.9rem;
				opacity: 0.95;
				line-height: 1.6;
			}

			.dark body {
				background: linear-gradient(135deg, #111827 0%, #0f172a 50%, #020617 100%);
			}

			.dark .posts-section h2 {
				color: #f9fafb;
			}

			.dark .posts-section > p {
				color: rgba(255, 255, 255, 0.72);
			}

			.dark .post-card {
				background: rgba(17, 24, 39, 0.95);
				border: 1px solid rgba(255, 255, 255, 0.08);
				box-shadow: 0 10px 30px rgba(2, 6, 23, 0.45), 0 1px 3px rgba(2, 6, 23, 0.35);
			}

			.dark .post-card:hover {
				box-shadow: 0 20px 45px rgba(2, 6, 23, 0.6), 0 2px 8px rgba(35, 55, 255, 0.2);
				border-color: rgba(35, 55, 255, 0.25);
			}

			.dark .post-image {
				background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
			}

			.dark .post-date {
				color: rgba(255, 255, 255, 0.6);
			}

			.dark .post-card h3 {
				color: #f9fafb;
			}

			.dark .post-description {
				color: rgba(255, 255, 255, 0.72);
			}

			.dark .post-link {
				color: #8bb4ff;
			}

			.dark .post-link:hover {
				color: #c7d9ff;
			}

			.dark .archive-link {
				border-top-color: rgba(255, 255, 255, 0.12);
			}

			.dark .archive-link a {
				box-shadow: 0 8px 20px rgba(35, 55, 255, 0.28);
			}

			.archive-link {
				text-align: center;
				margin-top: 3rem;
				padding-top: 3rem;
				border-top: 1px solid rgba(35, 55, 255, 0.1);
			}

			.archive-link .actions {
				display: flex;
				justify-content: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.archive-link a {
				display: inline-block;
				background: linear-gradient(135deg, #2337ff 0%, #1a25cc 100%);
				color: white;
				padding: 1rem 2.5rem;
				border-radius: 12px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				letter-spacing: 0.5px;
				box-shadow: 0 8px 20px rgba(35, 55, 255, 0.25);
				border: 1px solid transparent;
			}

			.archive-link a:hover {
				transform: translateY(-3px);
				box-shadow: 0 15px 40px rgba(35, 55, 255, 0.35);
				border-color: rgba(255, 255, 255, 0.2);
			}

			.archive-link a:active {
				transform: translateY(-1px);
			}

			@media (max-width: 640px) {
				.hero {
					padding: 3rem 1rem 2.5rem 1rem;
					margin: -3em -1em 2.5rem -1em;
				}

				.hero h1 {
					font-size: 2.25rem;
				}

				.hero p {
					font-size: 1rem;
				}

				.posts-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.posts-section h2 {
					font-size: 2rem;
				}

				.post-image {
					height: 200px;
				}

				.post-content {
					padding: 1.5rem;
				}

				.post-card h3 {
					font-size: 1.35rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>The Smuggler's Daughter</h1>
				<p>
					Follow John Buzzanca's journey from dangerous coastlines to the courtroom, and explore the visual
					story behind the book through a curated collection of images and the official trailer.
				</p>
			</div>

			<div class="posts-section">
				<video autoplay muted loop playsinline poster="/media/cover-1.webp">
					<source src="/media/trailer.mp4" type="video/mp4" />
				</video>
				<h2>Latest Stories</h2>
				<p>Explore our most recent narratives</p>
				<div class="posts-grid">
					{
						latestPosts.map((post) => (
							<article class="post-card">
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt={post.data.title} class="post-image" />
								)}
								<div class="post-content">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<h3>{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
									<a href={`/blog/${post.id}`} class="post-link">
										Read More →
									</a>
								</div>
							</article>
						))
					}
				</div>
			</div>

			<div class="stories-container">
				<a href="/blog" class="story-card" style="background-image: url('https://images.leadconnectorhq.com/image/f_webp/q_80/r_900/u_https://assets.cdn.filesafe.space/ryFFM2PahlMxJvflm1nc/media/68bb418c1ff6ea7b62f4df41.png');">
					<h3>Smuggling Story</h3>
					<p>Risk, power, and betrayal</p>
				</a>
				<a href="/blog" class="story-card" style="background-image: url('https://images.leadconnectorhq.com/image/f_webp/q_80/r_900/u_https://assets.cdn.filesafe.space/ryFFM2PahlMxJvflm1nc/media/68bb4899460af21778791eec.png');">
					<h3>Surrogate Story</h3>
					<p>Love, law, and legacy</p>
				</a>
			</div>

			<div class="archive-link">
				<div class="actions">
					<a href="/blog">View All Stories</a>
					<a href="/trailer">Watch the Trailer</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
